<% layout("/layout/boilerplate") -%>
<div class="row mt-3">
    <div  class="col-6 offset-3">
        <form action="/signup" method="POST" class="needs-validation" novalidate >
            <h1>Signup Page</h1>
            <div class="mb-3">
                <div class="mb-3">
                <label for="Username"  class="form-label">Username</label>
                <input type="text" class="form-control" name="username" id="username" required>
                <div class="valid-feedback">looks good!</div>
                <div class="invalid-feedback">Username Requirede!</div>
                </div>
                <div>
                <label for="Email1" class="form-label">Email address</label>
                <input type="email" class="form-control" name="email" id="email" aria-describedby="emailHelp" required>
                <div id="emailHelp" class="form-text">We'll never share your email with anyone else.</div>
                <div class="valid-feedback">looks good!</div>
                <div class="invalid-feedback">Email Requirede!</div>
            </div>
            </div>
            <div class="mb-3">
                <label for="Password" class="form-label">Password</label>
                <input type="password" name="password" class="form-control" id="password1" required>
                <div class="valid-feedback">looks good!</div>
                <div class="invalid-feedback">Password Requirede!</div>
            </div>
            <button type="submit" class="btn btn-primary">Signup</button>
        </form>
    </div>
</div>
