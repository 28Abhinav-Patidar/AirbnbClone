<% layout("/layout/boilerplate") -%>
<body>
    <!-- <form method="GET" action="/listing/new">
        <button>Add listing</button>
    </form> -->
    <div class="mb-4">
  <div class="row justify-content-center">
    <% for (listing of allListing ) { %>
      <div class="col-lg-4 col-md-6 col-sm-12 mb-4">
        <a href="/listing/<%= listing._id %>" class="text-decoration-none text-dark">
          <div class="card h-100 listing-card">
            <img src="<%= listing.image.url %>" class="card-img-top" alt="...">
            <div class="card-img-overlay"></div>
            <div class="card-body">
              <h6 class="card-title"><b><%= listing.title %></b></h6>
            </div>
            <ul class="list-group list-group-flush">
              <li class="list-group-item">
                Price : <b>&#8377;<%= listing.price ? listing.price.toLocaleString("en-IN") : "N/A" %></b> /night
              </li>
              <li class="list-group-item">
                Location : <%= listing.location %>
              </li>
              <li class="list-group-item">
                Country : <%= listing.country %>
              </li>
            </ul>
          </div>
        </a>
      </div>
    <% } %>
  </div>
</div>
</body>
