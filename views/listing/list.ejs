<% layout("/layout/boilerplate") -%>
    <body>
        <div class="row">
            <div class="col-6 offset-3">
        <div class="card listing-card">
    <img src="<%= list.image.url %>" class="card-img show-page-img" alt="...">
    <div class="card-body">
        <h5 class="card-title"><%= list.title %></h5>
        <p class="card-text">Owner: <%= list.owner.username %></p>
        <p class="card-text"> <%= list.description %></p>
        <h6>Price : &#8377;<%= list.price ? list.price.toLocaleString("en-IN") : "N/A" %></h6>
         <p class="card-text">Location: <%= list.location %>,<%= list.country %></p>
         <% if(currUser && currUser._id.equals(list.owner._id)) {%>
            <div class="btns">
                    <a href="/listing/<%= list._id %>/edit" class="btn btn-primary">Edit list</a>

                    <form method="POST" action="/listing/<%= list._id %>?_method=DELETE">
                        <button class="btn btn-danger">Delete</button>
                    </form>
                </div>
                <% } %>
        
    </div>
    </div>
    </div>
     <% if(currUser){ %>
    <div class="row">
        <div class="col-8 offset-2">
        <hr/>
       
        <div class="mt-3  ">
            <h4 class="d-flex justify-content-center">Leave Review</h4>
            <form action="/listing/<%= list._id %>/review" method="POST" novalidate class="needs-validation">
                <div>
                    <label for="Rating" class="form-label" >Rating</label>
               <fieldset class=" starability-fade">
                <input type="radio" id="no-rate" class="input-no-rate" name="review[Rating]" value="1" checked aria-label="No rating." />
                <input type="radio" id="second-rate1" name="review[Rating]" value="1" />
                <label for="second-rate1" title="Terrible">1 star</label>
                <input type="radio" id="second-rate2" name="review[Rating]" value="2" />
                <label for="second-rate2" title="Not good">2 stars</label>
                <input type="radio" id="second-rate3" name="review[Rating]" value="3" />
                <label for="second-rate3" title="Average">3 stars</label>
                <input type="radio" id="second-rate4" name="review[Rating]" value="4" />
                <label for="second-rate4" title="Very good">4 stars</label>
                <input type="radio" id="second-rate5" name="review[Rating]" value="5" />
                <label for="second-rate5" title="Amazing">5 stars</label>
                </fieldset>
                </div>
                <br/>
                 <div>
                    <label for="Comment" class="form-label" >Comment</label>
                    <textarea name="review[Comment]" id="Comment" class="form-control" rows="5" cols="30" required></textarea>
                    <div class="invalid-feedback">Comment Required!</div>
                </div>
                <br/>
                <button class="btn btn-success">Submit</button>
            </form>
        </div>
        </div>
        <% } %>
         <div class="mt-3 col-8 offset-2">
        <hr/>
       
        <h4 class="d-flex justify-content-center mb-3">All Reviews</h4>
        <div class="row">
        <% for(review of list.reviews) {%>
                <div class="card col-5 ms-5 mb-3 ">
                    <div class="card-body">
                        <h5 class="card-title">By : <%= review.author.username %></h5>
                        <p class="starability-result" data-rating=<%= review.Rating %>></p>
                        <p class="card-text"><strong>Review :</strong><%= review.Comment %></p>
                    </div>
                     <% if(currUser && currUser._id.equals(review.author._id)) {%>
                    <form class="card-body mb-2" method="POST" action="/listing/<%= list._id %>/review/<%= review._id %>?_method=DELETE">
                        <button class="btn btn-sm btn-dark">Delete</button>
                    </form>
                    <% } %>
                </div>
        <% }%>
     </div>
    </div>
    </div>
    </div>
</body>
