<% layout("/layout/boilerplate") -%>
<body>
    <div class="row">
        <div class="col-8 offset-2">
            <br/>  
    <form method="POST" action="/listing" class="mb-4 needs-validation" novalidate enctype="multipart/form-data">
            <div class="input-group mb-4">
        <span class="input-group-text" id="basic-addon1">Title</span>
        <input type="text" 
            id="title"
            name="listing[title]"
            class="form-control" 
            placeholder="Enter you title" 
            aria-label="title" 
            aria-describedby="basic-addon1" 
            required>
            <div class="valid-feedback">Title looks good!</div>
            <div class="invalid-feedback">Title Requirede!</div>
        </div>
        <div class="mb-4">

    <div class="d-flex justify-content-between align-items-center mb-2">

        <label class="form-label fw-bold">
            Description
        </label>

        <button
            type="button"
            id="generateAI"
            class="btn btn-outline-primary btn-sm">

            ✨ Generate AI

            </button>

        </div>

        <textarea
            id="description"
            name="listing[description]"
            class="form-control"
            rows="5"
            placeholder="Write description or generate it using AI..."
            required></textarea>

        <div class="invalid-feedback">
            Description Required!
        </div>

    </div>
        <div class="mb-4">
        <label for="basic-url" class="form-label">Upload Image</label>
        <div class="input-group">
            <input type="file"
            class="form-control"
            name="listing[image]"
            id="basic-url">
        </div>
        </div>
        <div class="row">
            <div class="col-md-4">
        <div class="input-group mb-4">
        <span class="input-group-text" > Price : &#8377;</span>
        <input name="listing[price]" id="price" class="form-control" aria-label="Amount" required>
        <div class="invalid-feedback">Please enter valid price!</div>
        <span class="input-group-text">.00</span>
        </div>
        </div>
         <div class="col-md-8">
         <div class="input-group mb-3">
            <input type="text" 
                id="country"
                name="listing[country]" 
                class="form-control" 
                placeholder="Country" 
                aria-label="country" 
                required>
                <div class="invalid-feedback">Please enter valid Country!</div>
        </div>
        </div>
        </div>
       <div class="input-group mb-3">
        <input type="text" id="location" name="listing[location]" class="form-control" placeholder="Location" aria-label="location" required>
        <div class="invalid-feedback">Please enter valid location!</div>
        </div>
        <button class="btn btn-primary">ADD</button>
       <br/>
        </form>
        </div>
    </div>
    <script src="/js/ai.js"></script>
</body>
